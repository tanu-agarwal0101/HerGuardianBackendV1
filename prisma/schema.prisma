generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  email              String              @unique
  isEmailVerified    Boolean             @default(false)
  password           String
  firstName          String?
  lastName           String?
  phoneNumber        String?
  location           String?
  bio                String?
  profilePicture     String?
  address            Address[]
  emergencyContacts  EmergencyContact[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  safetyTimers       SafetyTimer[]
  sosAlerts          SOSAlert[]
  pushSubscriptions  PushSubscription[]
  locationLogs       LocationLog[]
  sosTrackingSessions SOSTrackingSession[]
  stealthMode        Boolean             @default(false)
  stealthType        String?
  dashboardPass      String?
  sosPass            String?
  voiceTriggerPhrase String?             @default("Activate Emergency")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  role               String?              @default("user") 
  lastActiveAt       DateTime?            @default(now())
  linkedGuardians    GuardianLink[]      @relation("UserToGuardian")
  protectingUsers    GuardianLink[]      @relation("GuardianToUser")
  deviceStatus       DeviceStatus?
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
  expiresAt DateTime
  initialIssuedAt DateTime @default(now())
  rotatedFrom String? @db.ObjectId
  revoked   Boolean  @default(false)
  revokedAt DateTime?
  rememberMe Boolean @default(false)
  userAgent String?
  ip        String?
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BlackListToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model EmergencyContact {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  name         String
  phoneNumber  String
  relationship String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Address {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  type         String
  street       String?
  city         String?
  state        String?
  zipCode      String?
  country      String?
  latitude     Float?
  longitude    Float?
  radiusMeters Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SafetyTimer {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  duration       Int
  expiresAt      DateTime
  isActive       Boolean  @default(true)
  sharedLocation Boolean  @default(true)
  status         String   @default("active") // active, expired, cancelled
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  locationLogs   LocationLog[]
  sosAlerts      SOSAlert[]
}

model SOSAlert {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  timerId String? @db.ObjectId
  timer   SafetyTimer? @relation(fields: [timerId], references: [id])

  latitude    Float?
  longitude   Float?
  triggeredAt DateTime @default(now())
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?

  @@index([userId])
  @@index([timerId])
}

model LocationLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  timerId   String?  @db.ObjectId
  timer     SafetyTimer? @relation(fields: [timerId], references: [id])
  latitude  Float?
  longitude Float?
  event     String   @default("snapshot") // started | expired | cancelled | snapshot
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([timerId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model SOSTrackingSession {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  userId       String        @db.ObjectId
  user         User          @relation(fields: [userId], references: [id])
  token        String        @unique  // Secure public tracking token
  status       String        @default("active") // active | resolved | expired
  createdAt    DateTime      @default(now())
  expiresAt    DateTime                          // Hard expiry (6 hours from creation)
  lastUpdateAt DateTime?                         // Tracks last location push (for inactivity expiry)
  locations    SOSLocation[]

  @@index([userId])
  @@index([status])
}

model SOSLocation {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String             @db.ObjectId
  session   SOSTrackingSession @relation(fields: [sessionId], references: [id])
  latitude  Float
  longitude Float
  accuracy  Float?             // GPS accuracy in metres
  speed     Float?             // m/s — used for movement detection
  timestamp DateTime           @default(now())

  @@index([sessionId])        // Fast breadcrumb history queries
  @@index([timestamp])
}

// npx prisma format
// npx prisma reset
// npx prisma db push
// npx prisma generate

model GuardianLink {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  guardianId    String?  @db.ObjectId
  guardianEmail String?
  guardianPhone String?
  status        String   @default("pending")
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation("UserToGuardian", fields: [userId], references: [id])
  guardian      User?    @relation("GuardianToUser", fields: [guardianId], references: [id])

  @@index([userId])
  @@index([guardianId])
  @@index([expiresAt])
  @@index([status])
}

model DeviceStatus {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @unique @db.ObjectId
  user           User     @relation(fields: [userId], references: [id])
  batteryLevel   Float?
  isCharging     Boolean  @default(false)
  isOnline       Boolean  @default(true)
  connectionType String?
  updatedAt      DateTime @updatedAt
}
