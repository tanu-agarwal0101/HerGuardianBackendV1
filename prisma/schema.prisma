generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  email              String              @unique
  isEmailVerified    Boolean             @default(false)
  password           String
  firstName          String?
  lastName           String?
  phoneNumber        String?
  address            Address[]
  emergencyContacts  EmergencyContact[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  safetyTimers       SafetyTimer[]
  sosAlerts          SOSAlert[]
  pushSubscriptions  PushSubscription[]
  locationLogs       LocationLog[]
  stealthMode        Boolean             @default(false)
  stealthType        String?
  dashboardPass      String?
  sosPass            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
  expiresAt DateTime
  initialIssuedAt DateTime @default(now())
  rotatedFrom String? @db.ObjectId
  revoked   Boolean  @default(false)
  revokedAt DateTime?
  rememberMe Boolean @default(false)
  userAgent String?
  ip        String?
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BlackListToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model EmergencyContact {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  name         String
  phoneNumber  String
  relationship String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Address {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  type         String
  street       String?
  city         String?
  state        String?
  zipCode      String?
  country      String?
  latitude     Float?
  longitude    Float?
  radiusMeters Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SafetyTimer {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  duration       Int
  expiresAt      DateTime
  isActive       Boolean  @default(true)
  sharedLocation Boolean  @default(true)
  status         String   @default("active") // active, expired, cancelled
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  locationLogs   LocationLog[]
  sosAlerts      SOSAlert[]
}

model SOSAlert {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  timerId String? @db.ObjectId
  timer   SafetyTimer? @relation(fields: [timerId], references: [id])

  latitude    Float
  longitude   Float
  triggeredAt DateTime @default(now())
  resolved    Boolean  @default(false)

  @@index([userId])
  @@index([timerId])
}

model LocationLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  timerId   String?  @db.ObjectId
  timer     SafetyTimer? @relation(fields: [timerId], references: [id])
  latitude  Float
  longitude Float
  event     String   @default("snapshot") // started | expired | cancelled | snapshot
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([timerId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

